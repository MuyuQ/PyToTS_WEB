---
// Simple theme toggle button - click to switch between light and dark
---

<starlight-theme-toggle>
  <button type="button" aria-label="切换主题">
    <span class="icon-sun">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
    </span>
    <span class="icon-moon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </span>
  </button>
</starlight-theme-toggle>

<style>
  starlight-theme-toggle {
    display: flex;
    align-items: center;
  }

  button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  button:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  button:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .icon-sun,
  .icon-moon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
  }

  :global([data-theme="dark"]) .icon-sun {
    display: none;
  }

  :global([data-theme="light"]) .icon-moon {
    display: none;
  }

  /* Default to showing moon icon if no theme set (dark mode default) */
  :global(:not([data-theme="light"], [data-theme="dark"])) .icon-sun {
    display: none;
  }
</style>

<script is:inline>
  (function() {
    var THEME_KEY = 'starlight-theme';
    
    function getTheme() {
      var stored = localStorage.getItem(THEME_KEY);
      if (stored === 'light' || stored === 'dark') return stored;
      return 'dark';
    }
    
    function setTheme(theme) {
      var root = document.documentElement;
      root.setAttribute('data-theme', theme);
      localStorage.setItem(THEME_KEY, theme);
    }
    
    function toggleTheme() {
      var current = getTheme();
      setTheme(current === 'dark' ? 'light' : 'dark');
    }
    
    if (!customElements.get('starlight-theme-toggle')) {
      customElements.define('starlight-theme-toggle', class extends HTMLElement {
        constructor() {
          super();
          var btn = this.querySelector('button');
          if (btn) {
            btn.addEventListener('click', toggleTheme);
          }
        }
      });
    }
  })();
</script>