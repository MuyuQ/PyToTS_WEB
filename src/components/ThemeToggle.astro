---
// Theme toggle component for switching between light/dark themes
---

<button id="theme-toggle" aria-label="Toggle theme" class="theme-toggle">
  <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function updateIcons(theme: string) {
    toggle?.classList.toggle('dark', theme === 'dark');
  }

  // Initialize
  const currentTheme = html.getAttribute('data-theme') || 'light';
  updateIcons(currentTheme);

  toggle?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme') || 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateIcons(next);
  });
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: var(--radius-md);
    padding: 0.4rem;
    cursor: pointer;
    color: var(--sl-color-gray-2);
    transition: all var(--transition-fast);
  }

  .theme-toggle:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }

  .sun-icon { display: none; }
  .moon-icon { display: block; }

  .theme-toggle.dark .sun-icon { display: block; }
  .theme-toggle.dark .moon-icon { display: none; }
</style>
