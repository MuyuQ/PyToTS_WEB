---
interface Props {
  title: string;
  type?: "info" | "warning" | "tip" | "difference";
}

const { title, type = "difference" } = Astro.props;

const icons = {
  info: "ℹ️",
  warning: "⚠️",
  tip: "💡",
  difference: "≠",
};
---

<div 
  class:list={["diff-insight", `diff-insight--${type}`]} 
  role="note" 
  aria-label={`${type} 提示: ${title}`}
>
  <div class="insight-icon" aria-hidden="true">{icons[type]}</div>
  <div class="insight-content">
    <h4 class="insight-title">{title}</h4>
    <slot />
  </div>
</div>

<style>
  .diff-insight {
    display: flex;
    gap: var(--space-sm);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary);
    margin: var(--space-md) 0;
  }
  
  .diff-insight--difference {
    border-left-color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }
  
  .diff-insight--info {
    border-left-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }
  
  .diff-insight--warning {
    border-left-color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }
  
  .diff-insight--tip {
    border-left-color: #10b981;
    background: rgba(16, 185, 129, 0.1);
  }
  
  .insight-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  
  .insight-content {
    flex: 1;
  }
  
  .insight-title {
    margin: 0 0 var(--space-xs) 0;
    font-size: 0.95rem;
    font-weight: 600;
  }
  
  :global(.insight-content > p) {
    margin: 0;
  }
</style>