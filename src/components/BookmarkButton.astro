---
export interface Props {
  path: string;
  title: string;
}

const { path, title } = Astro.props;
---

<button
  class="bookmark-btn"
  data-path={path}
  data-title={title}
  aria-label="添加书签"
  title="添加到书签"
>
  <svg class="bookmark-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
  </svg>
</button>

<script>
  import { isBookmarked, addBookmark, removeBookmark } from '../lib/progress-store';

  function initBookmarkButtons() {
    const buttons = document.querySelectorAll('.bookmark-btn');

    buttons.forEach(button => {
      const path = button.getAttribute('data-path');
      if (!path) return;

      // 检查当前状态
      const bookmarked = isBookmarked(path);
      updateBookmarkUI(button as HTMLButtonElement, bookmarked);

      // 绑定点击事件
      button.addEventListener('click', () => {
        const isCurrentlyBookmarked = button.classList.contains('bookmarked');

        if (isCurrentlyBookmarked) {
          removeBookmark(path);
          updateBookmarkUI(button as HTMLButtonElement, false);
        } else {
          const title = button.getAttribute('data-title') || '';
          addBookmark(path);
          updateBookmarkUI(button as HTMLButtonElement, true);
        }
      });
    });
  }

  function updateBookmarkUI(button: HTMLButtonElement, bookmarked: boolean) {
    const icon = button.querySelector('.bookmark-icon');
    if (bookmarked) {
      button.classList.add('bookmarked');
      button.setAttribute('aria-label', '移除书签');
      button.setAttribute('title', '从书签移除');
      if (icon) icon.setAttribute('fill', 'currentColor');
    } else {
      button.classList.remove('bookmarked');
      button.setAttribute('aria-label', '添加书签');
      button.setAttribute('title', '添加到书签');
      if (icon) icon.setAttribute('fill', 'none');
    }
  }

  // 初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBookmarkButtons);
  } else {
    initBookmarkButtons();
  }
</script>

<style>
  .bookmark-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: transparent;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--sl-color-gray-3);
  }

  .bookmark-btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .bookmark-btn.bookmarked {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }

  .bookmark-btn:focus {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .bookmark-icon {
    width: 1.25rem;
    height: 1.25rem;
  }
</style>
